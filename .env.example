# --- SUPABASE CONFIG ---
# Get these from: Supabase Dashboard > Project Settings > API
# Replace with your project-specific URL and Anon Key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- EXTERNAL APIS ---
# Get from: https://perenual.com/docs/api
PERENUAL_API_KEY=your_perenual_api_key_here

# --- PLANTNET CONFIG ---
# Get from: https://my.plantnet.org/
PLANTNET_API_KEY=your_plantnet_api_key_here

# Project options: 'all' (Global), 'k-world-flora', etc.
PLANTNET_PROJECT=all